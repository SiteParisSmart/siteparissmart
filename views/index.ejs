<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Paris Smart-RX - Mode Championnat</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* 🎨 Stylisation de l'ascenseur personnalisé */
        .custom-scrollbar::-webkit-scrollbar {
            width: 6px;
        }
        .custom-scrollbar::-webkit-scrollbar-track {
            background: rgba(255, 255, 255, 0.02);
            border-radius: 10px;
        }
        .custom-scrollbar::-webkit-scrollbar-thumb {
            background: rgba(59, 130, 246, 0.4);
            border-radius: 10px;
            border: 1px solid rgba(255, 255, 255, 0.05);
        }
        .custom-scrollbar::-webkit-scrollbar-thumb:hover {
            background: rgba(59, 130, 246, 0.7);
        }
    </style>
</head>
<body class="text-white font-sans min-h-screen bg-cover bg-center bg-no-repeat bg-fixed" style="background-image: linear-gradient(to bottom, rgba(17, 24, 39, 0.85), rgba(17, 24, 39, 0.95)), url('https://images.unsplash.com/photo-1508098682722-e99c43a406b2?q=80&w=1920');">
    
    <nav class="bg-gray-800 border-b border-gray-700 sticky top-0 z-50 p-4">
        <div class="max-w-4xl mx-auto flex justify-between items-center">
            <div class="flex items-center gap-2">
                <span class="text-2xl">⚽</span>
                <h1 class="text-xl font-black italic text-blue-400 uppercase tracking-tighter">
                    Smart-Rx/DocaShop <span class="text-white">Prono</span>
                </h1>
            </div>
            <div class="flex items-center gap-3">
                <span class="text-sm hidden md:block text-gray-400">Salut, <strong class="text-white"><%= user.firstName %></strong></span>
                
                <a href="/faq" class="text-xs bg-gray-700 hover:bg-gray-600 text-white px-3 py-2 rounded-lg font-bold transition-colors">
                    ❓ FAQ & Règles
                </a>
                
                <a href="/logout" class="text-xs bg-red-600 hover:bg-red-500 text-white px-3 py-2 rounded-lg font-bold transition-colors">Déconnexion</a>
            </div>
        </div>
    </nav>

    <main class="max-w-4xl mx-auto p-6 space-y-10">
        
        <!-- 🏆 SECTION CLASSEMENT GÉNÉRAL -->
        <section class="bg-gray-800 p-6 rounded-3xl border border-yellow-500/30 shadow-2xl">
            <div class="flex items-center justify-between mb-6 gap-4">
                <img src="https://upload.wikimedia.org/wikipedia/commons/4/4b/2026_FIFA_World_Cup_emblem_%28without_trophy%29.svg" alt="FIFA 2026" class="h-10 md:h-12 opacity-90">
                <h2 class="text-xl md:text-2xl font-black text-white flex items-center gap-3 text-center tracking-wide">
                    <span class="text-2xl md:text-3xl text-yellow-400 hidden sm:inline">🏆</span> CLASSEMENT GÉNÉRAL
                </h2>
                <img src="https://upload.wikimedia.org/wikipedia/commons/4/4b/2026_FIFA_World_Cup_emblem_%28without_trophy%29.svg" alt="FIFA 2026" class="h-10 md:h-12 opacity-90">
            </div>
            
            <div class="max-h-[510px] overflow-y-auto pr-2 custom-scrollbar space-y-3">
                <% leaderboard.forEach((player, index) => { 
                    const playerBadges = player.badges || [];
                    const hasDevinDivin = playerBadges.includes('streak-10');

                    let cardClass = "bg-gray-900/50 border border-gray-700";
                    if (hasDevinDivin) {
                        cardClass = "bg-purple-950/40 border-2 border-purple-500 shadow-[0_0_15px_rgba(168,85,247,0.3)] animate-pulse-slow";
                    } else if (player.email === user.username) {
                        cardClass = "bg-yellow-500/20 border border-yellow-500/50";
                    }
                %>
                    <div class="flex items-center justify-between p-4 rounded-2xl <%= cardClass %>">
                        <div class="flex items-center gap-4">
                            <span class="text-xl font-black w-8 <%= index === 0 ? 'text-yellow-400' : (hasDevinDivin ? 'text-purple-400' : 'text-gray-500') %>">#<%= index + 1 %></span>
                            <div>
                                <div class="flex flex-wrap items-center gap-2">
                                    <p class="text-white font-bold flex items-center gap-2">
                                        <% if (hasDevinDivin) { %> <span>🔮</span> <% } %>
                                        <%= player.name %>
                                    </p>
                                    <% if(player.email === user.username) { %>
                                        <span class="text-[10px] bg-blue-600 text-white px-2 py-0.5 rounded-full font-black uppercase tracking-wider">Moi</span>
                                    <% } %>
                                    <% if(hasDevinDivin) { %>
                                        <span class="text-[9px] bg-purple-500 text-white px-2 py-0.5 rounded-full font-black uppercase tracking-wider shadow-sm">Légende</span>
                                    <% } %>
                                </div>

                                <!-- Vitrine des Succès -->
                                <div class="flex flex-wrap gap-1.5 mt-2 pt-1.5 border-t border-white/5">
                                    <% if (playerBadges.includes('streak-3')) { %>
                                        <span title="3 bons paris d'affilée !" class="cursor-help text-[9px] bg-orange-500/10 text-orange-400 border border-orange-500/20 px-2 py-0.5 rounded-md font-bold">🔥 Triplé Chaud</span>
                                    <% } %>
                                    <% if (playerBadges.includes('streak-5')) { %>
                                        <span title="5 bons paris d'affilée !" class="cursor-help text-[9px] bg-red-500/10 text-red-400 border border-red-500/20 px-2 py-0.5 rounded-md font-bold animate-pulse">⚡ Main Chaude</span>
                                    <% } %>
                                    <% if (hasDevinDivin) { %>
                                        <span title="LÉGENDAIRE : 10 bons paris d'affilée !" class="cursor-help text-[9px] bg-purple-500 text-white border border-purple-400 px-2 py-0.5 rounded-md font-black shadow-[0_0_8px_rgba(168,85,247,0.6)]">🔮 Devin Divin</span>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                        <div class="text-right">
                            <span class="text-2xl font-black <%= hasDevinDivin ? 'text-purple-300' : '' %>"><%= player.points %></span>
                            <span class="text-xs text-gray-400 uppercase ml-1">pts</span>
                        </div>
                    </div>
                <% }) %>
            </div>
        </section>

        <!-- ⚽ SECTION DES PARIS -->
        <section class="bg-gray-800 p-8 rounded-3xl border border-gray-700 shadow-2xl relative">
            <div id="statusBadge" class="absolute top-4 right-4 px-3 py-1 rounded-full text-[10px] font-black uppercase bg-green-500/20 text-green-400 border border-green-500/50">
                Ouvert
            </div>

            <h3 class="text-xl font-bold mb-8 text-blue-400 italic uppercase">⚽ Parier sur un match</h3>
            
            <form action="/bet" method="POST" id="betForm" class="space-y-6">
                <div>
                    <label class="block text-[10px] uppercase text-gray-500 mb-2 font-black tracking-widest text-center">Choisir l'affiche :</label>
                    <select name="matchId" id="matchSelect" class="w-full bg-gray-900 border border-gray-700 p-4 rounded-xl font-semibold text-white outline-none focus:border-blue-500" required>
                        <option value="">-- Sélectionnez un match --</option>
                        <% matches.forEach(match => { 
                            const alreadyBetted = bettedMatchIds.includes(match._id.toString());
                        %>
                            <option value="<%= match._id %>" 
                            data-c1="<%= match.code1 %>" 
                            data-c2="<%= match.code2 %>"
                            data-phase="<%= match.phase || 'seizieme' %>"
                            data-deadline="<%= match.date.getTime() - (2 * 60 * 60 * 1000) %>" 
                            <%= alreadyBetted ? 'disabled class="text-gray-600"' : '' %>>
                                [<%= (match.phase || '16e').toUpperCase() %>] <%= match.teams %> 
                                <%= alreadyBetted ? '✅ (Déjà parié)' : '— ' + new Date(match.date.getTime()).toLocaleString('fr-FR', {day:'2-digit', month:'2-digit', hour:'2-digit', minute:'2-digit'}) %>
                            </option>
                        <% }) %>
                    </select>
                </div>

                <!-- 💡 BAREME DES POINTS DYNAMIQUE -->
                <div id="pointsRuleBadge" class="hidden text-center p-3 rounded-xl text-xs font-bold border"></div>

                <div id="timerContainer" class="hidden bg-gray-900/50 border border-gray-700 p-4 rounded-2xl text-center">
                    <p class="text-[10px] text-gray-500 uppercase font-black mb-1">Fin des pronos dans :</p>
                    <div id="countdown" class="text-2xl font-black text-yellow-400 font-mono">--:--:--</div>
                </div>

                <!-- 🎛️ CONTENEUR OPTIONS DE JEU INJECTÉ DYNAMIQUEMENT -->
                <div id="dynamicPredictionContainer">
                    <p class="text-center text-xs text-gray-500 italic p-6 bg-gray-900/30 rounded-2xl border border-gray-700/50">
                        Sélectionnez un match ci-dessus pour afficher les options de pronostic.
                    </p>
                </div>

                <button type="submit" id="submitBtn" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-black py-4 rounded-xl shadow-lg transition text-lg uppercase disabled:opacity-50 disabled:cursor-not-allowed">
                    Valider mon pari
                </button>
            </form>
        </section>

        <!-- 📋 SECTION MES PRONOS -->
        <section class="bg-gray-800 p-6 rounded-3xl border border-gray-700 shadow-2xl">
            <h3 class="text-xl font-bold mb-6 px-2 text-blue-400 flex items-center gap-2 italic uppercase">📋 Mes Pronos</h3>
            <div class="grid gap-4">
                <% const myBets = bets.filter(b => b.user === user.username);
                   myBets.forEach(bet => { %>
                    <div class="bg-gray-900/50 p-5 rounded-3xl border border-gray-700 flex flex-col md:flex-row items-center gap-6 shadow-xl">
                        <div class="bg-gray-900 p-4 rounded-2xl w-20 h-20 flex flex-col items-center justify-center shrink-0 border border-gray-700">
                            <% 
                            let displayCode = null;
                            if (bet.score1 !== null && bet.score2 !== null) {
                                // En phase finale, on montre le drapeau de l'équipe qualifiée choisie (prediction)
                                if (bet.prediction === '1') displayCode = bet.code1;
                                else if (bet.prediction === '2') displayCode = bet.code2;
                            } else {
                                // Règle classique des poules / 16èmes
                                if (bet.prediction === '1') displayCode = bet.code1;
                                else if (bet.prediction === '2') displayCode = bet.code2;
                            }
                            
                            if(displayCode) { %>
                                <img src="https://flagcdn.com/w80/<%= displayCode.toLowerCase() %>.png" class="w-12 rounded shadow-sm">
                            <% } else { %>
                                <span class="text-2xl">🤝</span>
                            <% } %>
                        </div>
                        <div class="flex-1 text-center md:text-left">
                            <p class="text-xl font-black text-white"><%= bet.teams %></p>
                            <p class="text-xs font-bold text-blue-400 uppercase">
                                Pari : 
                                <span class="text-white">
                                    <% if (bet.score1 !== null && bet.score2 !== null) { %>
                                        Score : <%= bet.score1 %> - <%= bet.score2 %> 
                                        <% if (bet.score1 === bet.score2) { %>
                                            (Qualifié : <%= bet.prediction === '1' ? bet.teams.split(' - ')[0] : bet.teams.split(' - ')[1] %>)
                                        <% } %>
                                    <% } else { %>
                                        <%= bet.prediction === '1' ? bet.teams.split(' - ')[0] : (bet.prediction === '2' ? bet.teams.split(' - ')[1] : 'Match Nul') %>
                                    <% } %>
                                </span>
                            </p>
                        </div>
                        <button onclick="editBet('<%= bet._id %>', '<%= bet.matchId %>', '<%= bet.prediction || '' %>', '<%= bet.score1 !== null ? bet.score1 : '' %>', '<%= bet.score2 !== null ? bet.score2 : '' %>', '<%= bet.code1 %>', '<%= bet.code2 %>')" class="bg-gray-700 hover:bg-white hover:text-black text-gray-300 px-5 py-2 rounded-xl text-[10px] font-black uppercase transition-all">Modifier</button>
                    </div>
                <% }) %>
            </div>
        </section>
    </main>

<script>
    let countdownInterval;
    let isEditing = false;

    const betForm = document.getElementById('betForm');
    const matchSelect = document.getElementById('matchSelect');
    const dynamicContainer = document.getElementById('dynamicPredictionContainer');
    const timerContainer = document.getElementById('timerContainer');
    const countdownEl = document.getElementById('countdown');
    const submitBtn = document.getElementById('submitBtn');
    const statusBadge = document.getElementById('statusBadge');
    const pointsRuleBadge = document.getElementById('pointsRuleBadge');

    if (matchSelect) {
        matchSelect.addEventListener('change', function() {
            const opt = this.options[this.selectedIndex];
            if (!opt || opt.value === "") {
                timerContainer.classList.add('hidden');
                pointsRuleBadge.classList.add('hidden');
                dynamicContainer.innerHTML = `<p class="text-center text-xs text-gray-500 italic p-6 bg-gray-900/30 rounded-2xl border border-gray-700/50">Sélectionnez un match ci-dessus pour afficher les options de pronostic.</p>`;
                return;
            }

            const c1 = opt.getAttribute('data-c1') || 'un';
            const c2 = opt.getAttribute('data-c2') || 'un';
            const phase = opt.getAttribute('data-phase');
            const deadlineStr = opt.getAttribute('data-deadline');

            // 📢 Affichage de la bulle d'information sur les points selon la phase
            pointsRuleBadge.classList.remove('hidden');
            if (phase === 'huitieme' || phase === 'quart' || phase === 'demie' || phase === 'finale') {
                pointsRuleBadge.innerText = "💡 RÈGLE : Qualifié trouvé = 3 pts | Score exact (Fin du tps réglementaire) = +3 pts bonus !";
                pointsRuleBadge.className = "text-center p-3 rounded-xl text-xs font-bold bg-blue-950/40 border-blue-500/40 text-blue-300";
                
                // Formulaire Score Exact + Bloc qualification si nul
                dynamicContainer.innerHTML = `
                    <div class="bg-gray-900/40 p-6 rounded-2xl border border-gray-700/50 space-y-6">
                        <div class="grid grid-cols-2 gap-8">
                            <div class="flex flex-col items-center space-y-3">
                                <img src="https://flagcdn.com/w80/${c1.toLowerCase()}.png" class="w-16 h-10 object-cover rounded shadow-md border border-gray-700">
                                <label class="text-xs font-bold text-gray-400 uppercase tracking-wider">${opt.text.split(' - ')[0]?.split('] ')[1] || 'Équipe 1'}</label>
                                <input type="number" name="score1" id="score1Input" min="0" max="20" placeholder="0" class="w-20 bg-gray-900 border-2 border-gray-700 focus:border-blue-500 text-center text-2xl font-black py-2 rounded-xl text-white outline-none transition" required>
                            </div>
                            <div class="flex flex-col items-center space-y-3">
                                <img src="https://flagcdn.com/w80/${c2.toLowerCase()}.png" class="w-16 h-10 object-cover rounded shadow-md border border-gray-700">
                                <label class="text-xs font-bold text-gray-400 uppercase tracking-wider">${opt.text.split(' - ')[1]?.split(' — ')[0] || 'Équipe 2'}</label>
                                <input type="number" name="score2" id="score2Input" min="0" max="20" placeholder="0" class="w-20 bg-gray-900 border-2 border-gray-700 focus:border-blue-500 text-center text-2xl font-black py-2 rounded-xl text-white outline-none transition" required>
                            </div>
                        </div>

                        <!-- 🤝 SECTION SÉCURITÉ MATCH NUL (PROLONGATIONS / TAB) -->
                        <div id="qualificationBlock" class="hidden border-t border-gray-700/50 pt-4 text-center space-y-3">
                            <p class="text-xs font-bold text-yellow-400 uppercase">En cas de match nul, qui se qualifie au bout du suspense ?</p>
                            <div class="flex justify-center gap-4">
                                <label class="cursor-pointer">
                                    <input type="radio" name="qualifiedWinner" value="1" id="qualify1" class="peer hidden">
                                    <div class="peer-checked:bg-blue-600 peer-checked:text-white bg-gray-800 border border-gray-700 px-4 py-2 rounded-xl text-xs font-bold text-gray-400 transition-all">
                                        ${opt.text.split(' - ')[0]?.split('] ')[1] || 'Équipe 1'}
                                    </div>
                                </label>
                                <label class="cursor-pointer">
                                    <input type="radio" name="qualifiedWinner" value="2" id="qualify2" class="peer hidden">
                                    <div class="peer-checked:bg-blue-600 peer-checked:text-white bg-gray-800 border border-gray-700 px-4 py-2 rounded-xl text-xs font-bold text-gray-400 transition-all">
                                        ${opt.text.split(' - ')[1]?.split(' — ')[0] || 'Équipe 2'}
                                    </div>
                                </label>
                            </div>
                        </div>
                    </div>`;

                const s1 = document.getElementById('score1Input');
                const s2 = document.getElementById('score2Input');
                const qBlock = document.getElementById('qualificationBlock');
                const q1 = document.getElementById('qualify1');
                const q2 = document.getElementById('qualify2');

                function checkEquality() {
                    if(s1.value !== "" && s2.value !== "" && parseInt(s1.value) === parseInt(s2.value)) {
                        qBlock.classList.remove('hidden');
                        q1.required = true;
                    } else {
                        qBlock.classList.add('hidden');
                        q1.required = false;
                        q1.checked = false;
                        q2.checked = false;
                    }
                }
                s1.addEventListener('input', checkEquality);
                s2.addEventListener('input', checkEquality);

            } else {
                pointsRuleBadge.innerText = "💡 RÈGLE : Victoire simple = 3 points. Match nul possible à la fin des 90 minutes.";
                pointsRuleBadge.className = "text-center p-3 rounded-xl text-xs font-bold bg-gray-900/50 border-gray-700 text-gray-400";
                
                // Formulaire 1, N ou 2 classique des poules/16èmes
                dynamicContainer.innerHTML = `
                    <div class="grid grid-cols-3 gap-4">
                        <label class="cursor-pointer group">
                            <input type="radio" name="prediction" value="1" class="hidden peer" required>
                            <div class="peer-checked:bg-blue-600 peer-checked:border-transparent bg-gray-900 border-2 border-gray-700 p-4 rounded-2xl text-center transition flex flex-col items-center">
                                <img src="https://flagcdn.com/w80/${c1.toLowerCase()}.png" class="w-12 h-8 object-cover mb-2 rounded shadow-md border border-gray-700">
                                <span class="text-xs font-bold text-gray-400 peer-checked:text-white">Victoire Domicile</span>
                            </div>
                        </label>
                        <label class="cursor-pointer group">
                            <input type="radio" name="prediction" value="N" class="hidden peer">
                            <div class="peer-checked:bg-blue-600 peer-checked:border-transparent bg-gray-900 border-2 border-gray-700 p-4 rounded-2xl text-center transition flex flex-col items-center justify-center h-full">
                                <span class="text-2xl mb-1">🤝</span>
                                <span class="text-xs font-bold text-gray-400 peer-checked:text-white">Match Nul</span>
                            </div>
                        </label>
                        <label class="cursor-pointer group">
                            <input type="radio" name="prediction" value="2" class="hidden peer">
                            <div class="peer-checked:bg-blue-600 peer-checked:border-transparent bg-gray-900 border-2 border-gray-700 p-4 rounded-2xl text-center transition flex flex-col items-center">
                                <img src="https://flagcdn.com/w80/${c2.toLowerCase()}.png" class="w-12 h-8 object-cover mb-2 rounded shadow-md border border-gray-700">
                                <span class="text-xs font-bold text-gray-400 peer-checked:text-white">Victoire Extérieur</span>
                            </div>
                        </label>
                    </div>`;
            }

            // Gestion du Timer / Décompte
            clearInterval(countdownInterval);
            if (!deadlineStr) {
                timerContainer.classList.add('hidden');
                return;
            }

            timerContainer.classList.remove('hidden');
            const deadline = Number(deadlineStr); 

            countdownInterval = setInterval(() => {
                const now = new Date().getTime();
                const diff = deadline - now;

                if (diff <= 0) {
                    clearInterval(countdownInterval);
                    countdownEl.innerText = "COUP D'ENVOI PASSÉ";
                    submitBtn.disabled = true;
                    submitBtn.innerText = "TROP TARD !";
                    statusBadge.innerText = "Fermé";
                    statusBadge.className = "absolute top-4 right-4 px-3 py-1 rounded-full text-[10px] font-black uppercase bg-red-500/20 text-red-500 border border-red-500/50";
                    return;
                }

                const d = Math.floor(diff / (1000 * 60 * 60 * 24));
                const h = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
                const m = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                const s = Math.floor((diff % (1000 * 60)) / 1000);

                let text = (d > 0) ? d + "j " + (h < 10 ? "0"+h : h) + "h " + (m < 10 ? "0"+m : m) + "m" 
                                   : (h < 10 ? "0"+h : h) + ":" + (m < 10 ? "0"+m : m) + ":" + (s < 10 ? "0"+s : s);
                
                countdownEl.innerText = text;
                submitBtn.disabled = false;
                if (!isEditing) submitBtn.innerText = "Valider mon pari";
                statusBadge.innerText = "Ouvert";
                statusBadge.className = "absolute top-4 right-4 px-3 py-1 rounded-full text-[10px] font-black uppercase bg-green-500/20 text-green-400 border border-green-500/50";
            }, 1000);
        });
    }

    function editBet(betId, matchId, prediction, score1, score2, c1, c2) {
        isEditing = true;
        const optionToEnable = matchSelect.querySelector(`option[value="${matchId}"]`);
        if (optionToEnable) {
            optionToEnable.disabled = false;
            optionToEnable.classList.remove('text-gray-600');
        }

        matchSelect.value = matchId;
        matchSelect.dispatchEvent(new Event('change'));
        
        setTimeout(() => {
            if (score1 !== '' && score2 !== '') {
                const inputScore1 = document.getElementById('score1Input');
                const inputScore2 = document.getElementById('score2Input');
                if (inputScore1) {
                    inputScore1.value = score1;
                    inputScore1.dispatchEvent(new Event('input')); // Force l'apparition du bloc de qualif si égalité
                }
                if (inputScore2) {
                    inputScore2.value = score2;
                    inputScore2.dispatchEvent(new Event('input'));
                }
                
                // Si égalité, on coche la bonne radio de qualification
                if (parseInt(score1) === parseInt(score2) && prediction !== '') {
                    const qualifRadio = document.querySelector(`input[name="qualifiedWinner"][value="${prediction}"]`);
                    if (qualifRadio) qualifRadio.checked = true;
                }
            } else if (prediction !== '') {
                const radio = document.querySelector(`input[name="prediction"][value="${prediction}"]`);
                if (radio) radio.checked = true;
            }
        }, 100);

        let hiddenId = document.getElementById('editingBetId');
        if (!hiddenId) {
            hiddenId = document.createElement('input');
            hiddenId.type = 'hidden';
            hiddenId.name = 'betId';
            hiddenId.id = 'editingBetId';
            betForm.appendChild(hiddenId);
        }
        hiddenId.value = betId;
        
        submitBtn.innerText = "Confirmer la modification";
        window.scrollTo({ top: 0, behavior: 'smooth' });
    }
</script>
</body>
</html>